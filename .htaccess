RewriteEngine On

# -----------------------------------------
# Redirect unwanted query URLs to 404
# -----------------------------------------
RewriteCond %{QUERY_STRING} (^|&)(fwp|ref=aftership|p=p7001)(&|$) [NC]
RewriteRule ^$ /404.php? [L,R=404]

# -----------------------------------------
# 1. Redirect all HTTP to HTTPS
# -----------------------------------------
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# -----------------------------------------
# 2. Redirect non-www to www (including HTTPS)
# -----------------------------------------
RewriteCond %{HTTP_HOST} ^eastsideventilation\.ca$ [NC]
RewriteRule ^ https://www.eastsideventilation.ca%{REQUEST_URI} [L,R=301]

# -----------------------------------------
# 3. Redirect all .php URLs to clean URLs (visible)
# -----------------------------------------
RewriteCond %{THE_REQUEST} \s([^.]+)\.php[?\s] [NC]
RewriteRule ^ %1 [R=301,L]

# -----------------------------------------
# 4. Internally rewrite clean URLs to PHP files (supports folders like /blogs/)
# -----------------------------------------
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+)$ $1.php [L]

# -----------------------------------------
# 5. Custom 404 page
# -----------------------------------------
ErrorDocument 404 /404.php

# -----------------------------------------
# 6. PHP handler (cPanel generated)
# -----------------------------------------
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php82 .php .php8 .phtml
</IfModule>

# php -- BEGIN cPanel-generated handler, do not edit
# Set the “ea-php82” package as the default “PHP” programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php82 .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit

# -----------------------------------------
# 7. Localhost override for XAMPP
# -----------------------------------------
# cPanel's ea-php handler is not available in local XAMPP and can cause
# PHP files to download instead of execute.
<If "%{HTTP_HOST} =~ /^(localhost|127\.0\.0\.1)(:\d+)?$/">
  RemoveHandler .php .php8 .phtml
  AddType application/x-httpd-php .php .php8 .phtml
</If>
